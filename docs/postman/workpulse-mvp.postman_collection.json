  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "pm.environment.set('today', now.toISOString().slice(0, 10));",
          "pm.environment.set('year', String(now.getUTCFullYear()));",
          "pm.environment.set('month', String(now.getUTCMonth() + 1));"
        ]
      }
    }
  ],
